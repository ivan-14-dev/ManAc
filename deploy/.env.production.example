# ManAC Environment Variables - Production Template
# Copy this file to .env and fill in the values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=manac.ictu.loc,manac_backend.ictu.loc,localhost,127.0.0.1

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/manac
# Or use individual settings:
# DB_NAME=manac
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# CORS Settings
CORS_ALLOWED_ORIGINS=http://manac.ictu.loc,http://localhost:3000

# Email Settings (configure for your SMTP server)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@manac.ictu.loc

# Media Files
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/manac/media

# Static Files
STATIC_URL=/static/
STATIC_ROOT=/var/www/manac/static

# Vercel specific (if deploying to Vercel)
# VERCEL=True
