# ========================================
# ManAc FastAPI - Configuration
# ========================================

# ========================================
# DATABASE - PostgreSQL
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manac

# ========================================
# JWT - Authentication
# ========================================
SECRET_KEY=manac-super-secret-key-change-in-production-2024
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ========================================
# CORS - Cross-Origin Resource Sharing
# ========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ANDROID_EMULATOR_ORIGIN=http://10.0.2.2:8000
LOCAL_NETWORK_ORIGIN=http://192.168.1.100:8000

# ========================================
# EMAIL - SMTP Configuration
# ========================================
# Gmail SMTP example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=ManAc System

# ========================================
# APP CONFIGURATION
# ========================================
APP_NAME=ManAc
APP_VERSION=1.0.0
DEBUG=true

# ========================================
# SERVER CONFIGURATION
# ========================================
HOST=0.0.0.0
PORT=8000
